Cell[CellGroupData[{

Cell["\<\
3. Time propagator for each Fourier mode.

Each Fourier mode satisfies eta_k''(t) = omega2(k) eta_k(t). With eta_k(0)=0 \
and eta_k'(0)=vHat_k,

eta_k(t) = vHat_k Sinh[Sqrt[omega2(k)] t]/Sqrt[omega2(k)].

If omega2(k) < 0, this expression is equivalent to the usual oscillatory \
formula involving Sin[Sqrt[-omega2(k)] t].\
\>", "Section",ExpressionUUID->"993023c4-4a68-419e-8f54-6969cb57a466"],

Cell["\<\
tol = 10^-12;

growthKernel[lambda_?NumericQ, t_?NumericQ] :=
  If[Abs[lambda] < tol,
     t,
     Sinh[Sqrt[lambda] t]/Sqrt[lambda]
  ];

growthKernelDot[lambda_?NumericQ, t_?NumericQ] :=
  If[Abs[lambda] < tol,
     1,
     Cosh[Sqrt[lambda] t]
  ];\
\>", "Input",
 CellLabel->
  "In[107]:=",ExpressionUUID->"e79f2eaf-8e0e-445f-8c2b-0f14c4fc990f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
4. Initial vertical perturbation velocity at the interface.

The example below is periodic on [0,L]. The symbolic expression v0Expr is \
only used to define the numerical function v0. The Fourier projection below \
does not use symbolic integration.\
\>", "Section",ExpressionUUID->"de20c3ce-9849-4a09-a56a-38191b0b2d99"],

Cell[CellGroupData[{

Cell["\<\
U0 = 10^-3;

v0Expr = U0 Cos[3 x] + (2/5) U0 Sin[5 x];

v0[xVal_?NumericQ] := N[v0Expr /. x -> xVal];

Plot[
  v0[x],
  {x, 0, Lnum},
  AxesLabel -> {\"x\", \"v0(x)\"},
  PlotLabel -> \"Initial interfacial vertical velocity\"
]\
\>", "Input",
 CellLabel->
  "In[112]:=",ExpressionUUID->"561d1467-186d-46ad-85ed-661a904c812e"],

