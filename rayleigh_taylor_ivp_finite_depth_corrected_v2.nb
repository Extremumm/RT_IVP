Cell[CellGroupData[{

Cell["\<\
5. Fourier coefficients without NIntegrate.

The coefficient convention is

vHat[n] = (1/L) Integral_0^L v0(x) Exp[-I k_n x] dx, k_n = 2 Pi n/L.

To avoid NIntegrate errors during Plot, the integral is approximated by the \
periodic trapezoidal rule. This is spectrally accurate for smooth periodic \
functions and exact up to roundoff for the present trigonometric polynomial \
if nSamples is sufficiently large.\
\>", "Section",ExpressionUUID->"c1f0728c-6d5e-4a85-a3c7-77d638072e91"],

Cell[CellGroupData[{

Cell["\<\
nMax = 32;

kn[n_Integer] := 2 Pi n/Lnum;

modes = Join[Range[-nMax, -1], Range[1, nMax]];

nSamples = 4096;

xGrid = N[Lnum Range[0, nSamples - 1]/nSamples];
v0Grid = v0 /@ xGrid;

Clear[vHat];

vHat[n_Integer] := vHat[n] =
  Chop[
    (1/nSamples) Total[v0Grid Exp[-I kn[n] xGrid]],
    10^-14
  ];

Table[
  {n, kn[n], vHat[n]},
  {n, -6, 6}
]\
\>", "Input",
 CellLabel->
  "In[119]:=",ExpressionUUID->"184e4dbb-03ba-4d93-a05d-28c0f38fa8e4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "6"}], ",", 
     RowBox[{"-", "6.`"}], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "5"}], ",", 
     RowBox[{"-", "5.`"}], ",", 
     RowBox[{"0.`", "\[VeryThinSpace]", "+", 
      RowBox[{"0.00019999999999999998`", " ", "\[ImaginaryI]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "4"}], ",", 
     RowBox[{"-", "4.`"}], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "3"}], ",", 
     RowBox[{"-", "3.`"}], ",", "0.0004999999999999984`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "2"}], ",", 
     RowBox[{"-", "2.`"}], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", "1.`"}], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0.`", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1.`", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "2.`", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3.`", ",", "0.0004999999999999984`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"4", ",", "4.`", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"5", ",", "5.`", ",", 
     RowBox[{"0.`", "\[VeryThinSpace]", "-", 
      RowBox[{"0.00019999999999999998`", " ", "\[ImaginaryI]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"6", ",", "6.`", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.987297437030354*^9, {3.987302356509202*^9, 3.987302381065209*^9}},
 CellLabel->
  "Out[134]=",ExpressionUUID->"afb63b08-aa34-4e88-9a91-8a40717a2fcb"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
6. Reconstruct the interface displacement eta(x,t) and the interfacial \
velocity eta_t(x,t).

All summations are evaluated numerically. The real part is taken because the \
physical perturbation is real-valued.\
\>", "Section",ExpressionUUID->"1944b005-be98-409c-870a-59c5599a797f"],

Cell["\<\
etaHat[n_Integer, tVal_?NumericQ] :=
  vHat[n] growthKernel[omega2Num[Abs[kn[n]]], tVal];

eta[xVal_?NumericQ, tVal_?NumericQ] :=
  Re[
    Total[
      etaHat[#, tVal] Exp[I kn[#] xVal] & /@ modes
    ]
  ];

wInterfaceHat[n_Integer, tVal_?NumericQ] :=
  vHat[n] growthKernelDot[omega2Num[Abs[kn[n]]], tVal];

wInterface[xVal_?NumericQ, tVal_?NumericQ] :=
  Re[
    Total[
      wInterfaceHat[#, tVal] Exp[I kn[#] xVal] & /@ modes
    ]
  ];\
\>", "Input",
 CellLabel->
  "In[135]:=",ExpressionUUID->"7bdbc263-6744-43cf-9e46-e6a4cb47a1cb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
7. Verify eta(x,0)=0 and eta_t(x,0)=v0(x).

This cell no longer calls NIntegrate. If NIntegrate messages still appear, \
the kernel still contains old definitions; evaluate the first cell again or \
choose Evaluation > Quit Kernel > Local, then evaluate the notebook from the \
beginning.\
\>", "Section",ExpressionUUID->"65064c2e-aa50-4c50-abbf-45a0408b65c7"],

Cell[CellGroupData[{

Cell["\<\
Plot[
  Evaluate[{eta[x, 0], wInterface[x, 0], v0[x]}],
  {x, 0, Lnum},
  PlotLegends -> {\"eta(x,0)\", \"eta_t(x,0)\", \"v0(x)\"},
  AxesLabel -> {\"x\", \"amplitude\"},
  PlotLabel -> \"Verification of the initial conditions\"
]\
\>", "Input",
 CellChangeTimes->{{3.9873023216784887`*^9, 3.987302326786353*^9}, {
  3.9873024035857363`*^9, 
  3.9873024138375483`*^9}},ExpressionUUID->"7a5496bf-5029-4049-8d09-\
db07dddb175f"],

