Cell[CellGroupData[{

Cell["\<\
8. Vertical velocity fields in the two fluids.

The vertical shape functions satisfy w1(H1)=0 and w2(-H2)=0, while \
w1(0)=w2(0)=eta_t(x,t).\
\>", "Section",ExpressionUUID->"d33a38d2-23bc-4074-aa60-a1f5037000e3"],

Cell["\<\
shape1[k_?NumericQ, zVal_?NumericQ] :=
  Sinh[k ((H1 /. pars) - zVal)]/Sinh[k (H1 /. pars)];

shape2[k_?NumericQ, zVal_?NumericQ] :=
  Sinh[k (zVal + (H2 /. pars))]/Sinh[k (H2 /. pars)];

w1[xVal_?NumericQ, zVal_?NumericQ, tVal_?NumericQ] :=
  Re[
    Total[
      (wInterfaceHat[#, tVal] shape1[Abs[kn[#]], zVal] Exp[I kn[#] xVal]) & \
/@ modes
    ]
  ];

w2[xVal_?NumericQ, zVal_?NumericQ, tVal_?NumericQ] :=
  Re[
    Total[
      (wInterfaceHat[#, tVal] shape2[Abs[kn[#]], zVal] Exp[I kn[#] xVal]) & \
/@ modes
    ]
  ];\
\>", "Input",
 CellLabel->
  "In[150]:=",ExpressionUUID->"9ee1026e-8617-4ee4-a8f9-d1a093a54cd1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["9. Verify the impermeability conditions at the walls.", "Section",ExpressionUUID->"2e17b85e-6eb8-4f34-ba82-28714614bd1d"],

Cell[CellGroupData[{

Cell["\<\
Plot[
  Evaluate[
    {
      w1[x, H1 /. pars, 0],
      w2[x, -(H2 /. pars), 0]
    }
  ],
  {x, 0, Lnum},
  PlotLegends -> {\"w1 at upper wall\", \"w2 at lower wall\"},
  AxesLabel -> {\"x\", \"wall-normal velocity\"},
  PlotLabel -> \"Verification of wall impermeability\"
]\
\>", "Input",
 CellLabel->
  "In[157]:=",ExpressionUUID->"46c0d424-cced-4392-9a85-bb3b36ebf0de"],

