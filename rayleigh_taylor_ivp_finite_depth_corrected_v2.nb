Cell["A numerical error check is often clearer than a plot.", "Text",ExpressionUUID->"21fdbf10-2204-46eb-ab65-6bbe4a846c0e"],

Cell[CellGroupData[{

Cell["\<\
checkGrid = N[Lnum Range[0, 512]/512];

maxEtaInitialError =
  Max[Abs[eta[#, 0] & /@ checkGrid]];

maxVelocityInitialError =
  Max[Abs[(wInterface[#, 0] - v0[#]) & /@ checkGrid]];

{maxEtaInitialError, maxVelocityInitialError}\
\>", "Input",
 CellLabel->
  "In[143]:=",ExpressionUUID->"e3876754-b646-4ab4-9cf2-fd4c03568b9c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.`", ",", "3.469446951953614`*^-18"}], "}"}]], "Output",
