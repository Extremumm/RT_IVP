Cell[CellGroupData[{

Cell["\<\
maxUpperWallError =
  Max[Abs[w1[#, H1 /. pars, 0] & /@ checkGrid]];

maxLowerWallError =
  Max[Abs[w2[#, -(H2 /. pars), 0] & /@ checkGrid]];

{maxUpperWallError, maxLowerWallError}\
\>", "Input",
 CellLabel->
  "In[158]:=",ExpressionUUID->"030f5fef-76ed-4c07-85bd-72cc1528ad0a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.`", ",", "0.`"}], "}"}]], "Output",
