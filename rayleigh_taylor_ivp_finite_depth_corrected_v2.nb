 CellLabel->
  "Out[162]=",ExpressionUUID->"072b7e85-0b0e-4c03-abb4-1ad5ace9f4b6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Interface evolution.", "Section",ExpressionUUID->"0a0d9652-f654-433d-87d8-dc25a9b7886a"],

Cell[CellGroupData[{

Cell["\<\
tMax = 1.0;

Plot3D[
  eta[x, t],
  {x, 0, Lnum},
  {t, 0, tMax},
  AxesLabel -> {\"x\", \"t\", \"\[Eta](x,t)\"},
  PlotRange -> All,
  Mesh -> None,
  PlotLabel -> \"Interface displacement eta(x,t)\"
]\
\>", "Input",
 CellLabel->
  "In[163]:=",ExpressionUUID->"9e268459-e4ca-4e47-996b-b2cf3551bb57"],

